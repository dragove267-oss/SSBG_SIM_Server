<%- include('partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 text-gray-800">유저 관리</h1>
</div>

<div class="card shadow mb-4">
    <div class="card-body">
        <form action="/users" method="GET" class="row g-2 mb-4">
            <div class="col-md-4">
                <div class="input-group">
                    <span class="input-group-text bg-light border-0"><i class="bi bi-search"></i></span>
                    <input type="text" name="search" class="form-control bg-light border-0" placeholder="유저 ID 검색..." value="<%= search %>">
                    <button type="submit" class="btn btn-primary">검색</button>
                </div>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>유저 ID</th>
                        <th>Academic</th>
                        <th>Extra</th>
                        <th>Idle</th>
                        <th>EXP</th>
                        <th>최종 활동</th>
                        <th class="text-center">액션</th>
                    </tr>
                </thead>
                <tbody>
                    <% users.forEach(user => { %>
                    <tr>
                        <td class="fw-bold"><%= user.userId %></td>
                        <td><span class="text-primary fw-semibold"><%= user.academicCurrency.toLocaleString() %></span></td>
                        <td><span class="text-success fw-semibold"><%= user.extraCurrency.toLocaleString() %></span></td>
                        <td><span class="text-warning fw-semibold"><%= user.idleCurrency.toLocaleString() %></span></td>
                        <td><span class="text-secondary fw-semibold"><%= user.exp.toLocaleString() %></span></td>
                        <td class="small text-muted"><%= user.updatedAt %></td>
                        <td class="text-center">
                            <a href="/users/<%= user.userId %>" class="btn btn-sm btn-outline-primary shadow-sm">
                                <i class="bi bi-pencil-square me-1"></i>수정
                            </a>
                        </td>
                    </tr>
                    <% }) %>
                    <% if(users.length === 0) { %>
                        <tr><td colspan="7" class="text-center py-5 text-muted">등록된 유저가 없습니다.</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
