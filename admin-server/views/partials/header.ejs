<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SSBG 어드민 대시보드</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        :root {
            --sidebar-width: 260px;
            --primary-color: #4e73df;
        }
        body { background-color: #f4f7f6; font-family: 'Pretendard', -apple-system, sans-serif; }
        .sidebar { 
            width: var(--sidebar-width);
            min-height: 100vh; 
            background: #1a1c23; 
            color: #9ea0a5;
            transition: all 0.3s;
        }
        .sidebar .nav-link { 
            color: #9ea0a5; 
            padding: 12px 20px; 
            display: flex;
            align-items: center;
            font-size: 0.95rem;
            border-left: 4px solid transparent;
        }
        .sidebar .nav-link:hover { background: #24262d; color: #fff; }
        .sidebar .nav-link.active { 
            background: #24262d; 
            color: #fff; 
            border-left-color: var(--primary-color);
        }
        .sidebar .nav-link i { margin-right: 12px; font-size: 1.1rem; }
        .sidebar .brand { padding: 25px 20px; color: #fff; font-weight: 700; font-size: 1.25rem; }
        
        .content { margin-left: 0; padding: 30px; width: 100%; }
        @media (min-width: 768px) {
            .content { width: calc(100% - var(--sidebar-width)); }
        }
        
        .card { border: none; border-radius: 12px; box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075); margin-bottom: 24px; }
        .card-header { background-color: #fff; border-bottom: 1px solid #edf2f9; padding: 15px 20px; font-weight: 600; }
        .table thead th { background-color: #f8f9fc; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.05em; border-top: none; }
        .btn-primary { background-color: var(--primary-color); border-color: var(--primary-color); }
    </style>
</head>
<body>
<div class="container-fluid p-0 d-flex">
    <!-- 사이드바 -->
    <nav class="sidebar d-none d-md-block">
        <div class="brand">
            <i class="bi bi-cpu-fill me-2"></i>SSBG Admin
        </div>
        <ul class="nav flex-column mt-2">
            <li class="nav-item">
                <a href="/" class="nav-link <%= (typeof page !== 'undefined' && page === 'dashboard') ? 'active' : '' %>">
                    <i class="bi bi-speedometer2"></i>대시보드
                </a>
            </li>
            <li class="nav-item">
                <a href="/users" class="nav-link <%= (typeof page !== 'undefined' && page === 'users') ? 'active' : '' %>">
                    <i class="bi bi-people"></i>유저 관리 (재화/연결)
                </a>
            </li>
            <li class="nav-item">
                <a href="/academic" class="nav-link <%= (typeof page !== 'undefined' && page === 'academic') ? 'active' : '' %>">
                    <i class="bi bi-mortarboard"></i>학사 데이터 관리
                </a>
            </li>
            <li class="nav-item">
                <a href="/items" class="nav-link <%= (typeof page !== 'undefined' && page === 'items') ? 'active' : '' %>">
                    <i class="bi bi-box-seam"></i>아이템 도감 관리
                </a>
            </li>
            <li class="nav-item mt-4 px-3">
                <small class="text-uppercase text-muted fw-bold" style="font-size: 0.7rem;">System</small>
            </li>
            <li class="nav-item">
                <a href="/logs" class="nav-link <%= (typeof page !== 'undefined' && page === 'logs') ? 'active' : '' %>">
                    <i class="bi bi-journal-text"></i>시스템 로그
                </a>
            </li>
            <li class="nav-item">
                <a href="/system" class="nav-link text-danger <%= (typeof page !== 'undefined' && page === 'system') ? 'active' : '' %>">
                    <i class="bi bi-gear-fill"></i>시스템 초기화
                </a>
            </li>
        </ul>
    </nav>
    
    <!-- 메인 콘텐츠 -->
    <main class="content">
