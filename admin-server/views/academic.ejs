<%- include('partials/header', { page: 'academic' }) %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 text-gray-800">학사 데이터 관리</h1>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addStudentModal">
        <i class="bi bi-plus-lg me-1"></i>신규 학번 등록
    </button>
</div>

<div class="card shadow mb-4 border-0">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">학번 (Student ID)</th>
                        <th>출석 횟수</th>
                        <th>과제 제출</th>
                        <th>연결된 유저</th>
                        <th class="text-center">관리</th>
                    </tr>
                </thead>
                <tbody>
                    <% students.forEach(s => { %>
                    <tr>
                        <td class="ps-4 fw-bold text-primary"><%= s.studentId %></td>
                        <td><span class="badge bg-info text-dark"><%= s.attCount %>회</span></td>
                        <td><span class="badge bg-success"><%= s.asgnCount %>개</span></td>
                        <td>
                            <% if(s.userId) { %>
                                <span class="badge bg-success-subtle text-success border border-success-subtle px-2">
                                    <i class="bi bi-link-45deg me-1"></i><%= s.userId %>
                                </span>
                            <% } else { %>
                                <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-2">
                                    미연결
                                </span>
                            <% } %>
                        </td>
                        <td class="text-center">
                            <a href="/academic/<%= s.studentId %>" class="btn btn-sm btn-outline-primary shadow-sm">
                                <i class="bi bi-gear-fill me-1"></i>상세 관리
                            </a>
                        </td>
                    </tr>
                    <% }) %>
                    <% if(students.length === 0) { %>
                        <tr><td colspan="5" class="text-center py-5 text-muted">등록된 학사 데이터가 없습니다.</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- 학번 등록 모달 -->
<div class="modal fade" id="addStudentModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header"><h5>신규 학번 등록</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
      <form action="/academic/add-student" method="POST">
        <div class="modal-body">
            <div class="mb-3">
                <label class="form-label small fw-bold">등록할 학번</label>
                <input type="text" name="studentId" class="form-control" placeholder="예: 20240001" required>
            </div>
        </div>
        <div class="modal-footer"><button type="submit" class="btn btn-primary">등록 및 관리</button></div>
      </form>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
